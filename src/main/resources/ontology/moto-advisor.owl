    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/moto-advisor#AFRICATWIN -->


    <owl:NamedIndividual rdf:about="http://example.org/moto-advisor#AFRICATWIN">
        <rdf:type rdf:resource="http://example.org/moto-advisor#AdventureBike"/>
        <rdf:type rdf:resource="http://example.org/moto-advisor#Motorcycle"/>
        <available rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</available>
        <engineSizeCc rdf:datatype="http://www.w3.org/2001/XMLSchema#int">1084</engineSizeCc>
        <experienceLevel>INTERMEDIATE</experienceLevel>
        <hasBrand>Honda</hasBrand>
        <hasCategory>ADVENTURE</hasCategory>
