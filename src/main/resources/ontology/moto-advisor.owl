<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/moto-advisor#"
     xml:base="http://example.org/moto-advisor"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/moto-advisor"/>

    <!-- Classes -->
    <owl:Class rdf:about="http://example.org/moto-advisor#Motorcycle"/>
    <owl:Class rdf:about="http://example.org/moto-advisor#SportBike">
        <rdfs:subClassOf rdf:resource="http://example.org/moto-advisor#Motorcycle"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/moto-advisor#NakedBike">
        <rdfs:subClassOf rdf:resource="http://example.org/moto-advisor#Motorcycle"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/moto-advisor#TouringBike">
        <rdfs:subClassOf rdf:resource="http://example.org/moto-advisor#Motorcycle"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/moto-advisor#AdventureBike">
        <rdfs:subClassOf rdf:resource="http://example.org/moto-advisor#Motorcycle"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/moto-advisor#CruiserBike">
        <rdfs:subClassOf rdf:resource="http://example.org/moto-advisor#Motorcycle"/>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/moto-advisor#CommuterBike">
        <rdfs:subClassOf rdf:resource="http://example.org/moto-advisor#Motorcycle"/>
    </owl:Class>

    <!-- Datatype properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#hasModelCode"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#hasBrand"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#hasModelName"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#hasCategory"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#engineSizeCc"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#priceEur"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#seatHeightMm"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#weightKg"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#experienceLevel"/>
    <owl:DatatypeProperty rdf:about="http://example.org/moto-advisor#available"/>

    <!-- Seed dataset (20 motorcycles) -->
